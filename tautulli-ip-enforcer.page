$plugin_url = "/plugins/tautulli-ip-enforcer/";
$plugin_config = "/boot/config/plugins/tautulli-ip-enforcer/settings.cfg";
$default_script_path = "/mnt/user/appdata/tautulli/Tautulli_IP_Enforcer/";
$github_repo = "https://github.com/jeremiejt38/Tautulli_IP_Enforcer.git";

// Load or create settings
if (file_exists($plugin_config)) {
    $settings = parse_ini_file($plugin_config);
    $script_path = $settings['script_path'] ?? $default_script_path;
    $setup_completed = $settings['setup_completed'] ?? false;
    $tautulli_ip = $settings['tautulli_ip'] ?? '172.17.0.20';
    $tautulli_port = $settings['tautulli_port'] ?? '8181';
    $tautulli_api = $settings['tautulli_api'] ?? '';
    $blacklist_msg = $settings['blacklist_msg'] ?? 'PLEX IP ENFORCER - BLACKLISTED';
    $concurrent_msg = $settings['concurrent_msg'] ?? 'PLEX IP ENFORCER - EXCESSIVE ACCOUNT SHARING';
} else {
    $script_path = $default_script_path;
    $setup_completed = false;
    $tautulli_ip = '172.17.0.20';
    $tautulli_port = '8181';
    $tautulli_api = '';
    $blacklist_msg = 'PLEX IP ENFORCER - BLACKLISTED';
    $concurrent_msg = 'PLEX IP ENFORCER - EXCESSIVE ACCOUNT SHARING';
}

// File paths
$banned_ips_file = $script_path . "banned_ips.txt";
$concurrent_limit_file = $script_path . "concurrent_ip_limit.txt";
$enforce_log_file = $script_path . "enforce_log.txt";
$python_script = $script_path . "tautulliIpEnforcer.py";

// ===========================================
// ACTION HANDLERS
// ===========================================

$message = "";
$message_type = "info";

// Setup Wizard Action
if ($_SERVER['REQUEST_METHOD'] === 'POST' && isset($_POST['action']) && $_POST['action'] === 'run_setup') {
    $sp = rtrim($_POST['script_path'], '/') . '/';
    if (!is_dir($sp)) { mkdir($sp, 0755, true); }
    exec("which git", $out, $ret);
    if ($ret !== 0) { $message = "Erreur: Git n'est pas installe"; $message_type = "error"; }
    else {
        if (is_dir($sp . ".git")) { exec("cd {$sp} && git pull 2>&1", $output, $ret); }
        else { exec("git clone {$github_repo} {$sp} 2>&1", $output, $ret); }
        if ($ret !== 0) { $message = "Erreur clonage: " . implode(" ", $output); $message_type = "error"; }
        else {
            file_put_contents($sp . "banned_ips.txt", file_exists($sp . "banned_ips.txt") ? "" : "");
            file_put_contents($sp . "concurrent_ip_limit.txt", file_exists($sp . "concurrent_ip_limit.txt") ? "" : "");
            $config = "script_path={$sp}\nsetup_completed=1\ntautulli_ip={$tautulli_ip}\ntautulli_port={$tautulli_port}\ntautulli_api={$tautulli_api}\nblacklist_msg={$blacklist_msg}\nconcurrent_msg={$concurrent_msg}\n";
            file_put_contents($plugin_config, $config);
            $message = "Installation terminee!"; $message_type = "success";
            $setup_completed = true;
            $settings = parse_ini_file($plugin_config);
            $script_path = $settings['script_path'];
        }
    }
}

// Save Settings Action
if ($_SERVER['REQUEST_METHOD'] === 'POST' && isset($_POST['action']) && $_POST['action'] === 'save_settings') {
    $sp = rtrim($_POST['script_path'], '/') . '/';
    $tip = $_POST['tautulli_ip'];
    $tp = $_POST['tautulli_port'];
    $ta = $_POST['tautulli_api'];
    $bm = $_POST['blacklist_msg'];
    $cm = $_POST['concurrent_msg'];
    $config = "script_path={$sp}\nsetup_completed=1\ntautulli_ip={$tip}\ntautulli_port={$tp}\ntautulli_api={$ta}\nblacklist_msg={$bm}\nconcurrent_msg={$cm}\n";
    file_put_contents($plugin_config, $config);
    updatePythonScript($sp, $tip, $tp, $ta, $bm, $cm);
    $message = "Parametres sauvegardes!"; $message_type = "success";
    $settings = parse_ini_file($plugin_config);
    $setup_completed = true;
}

// BANNED IPs ACTIONS
if ($_SERVER['REQUEST_METHOD'] === 'POST' && isset($_POST['action'])) {
    switch ($_POST['action']) {
        case 'add_banned_ip':
            $ip = trim($_POST['ip_address']);
            if (filter_var($ip, FILTER_VALIDATE_IP)) {
                $c = file_exists($banned_ips_file) ? file_get_contents($banned_ips_file) : "";
                $lines = array_filter(array_map('trim', explode("\n", $c)));
                if (!in_array($ip, $lines)) { file_put_contents($banned_ips_file, $ip . "\n", FILE_APPEND); $message = "IP ajoutee"; $message_type = "success"; }
                else { $message = "IP deja existante"; $message_type = "warning"; }
            } else { $message = "IP invalide"; $message_type = "error"; }
            break;
        case 'delete_banned_ip':
            $ip = trim($_POST['ip_address']);
            $c = file_exists($banned_ips_file) ? file_get_contents($banned_ips_file) : "";
            $lines = array_filter(array_map('trim', explode("\n", $c)), fn($l) => $l !== $ip);
            file_put_contents($banned_ips_file, implode("\n", $lines) . ($lines ? "\n" : ""));
            $message = "IP supprimee"; $message_type = "success";
            break;
        case 'import_banned_ips':
            $c = trim($_POST['ips_content']);
            $lines = array_filter(array_map('trim', explode("\n", $c)), fn($l) => filter_var($l, FILTER_VALIDATE_IP));
            file_put_contents($banned_ips_file, implode("\n", $lines) . "\n");
            $message = count($lines) . " IPs importees"; $message_type = "success";
            break;
        case 'clear_banned_ips':
            file_put_contents($banned_ips_file, ""); $message = "Liste vidée"; $message_type = "success"; break;
        // USER LIMITS
        case 'add_user_limit':
            $u = trim($_POST['username']); $l = intval($_POST['ip_limit']);
            if (!empty($u) && $l > 0) {
                $c = file_exists($concurrent_limit_file) ? file_get_contents($concurrent_limit_file) : "";
                $lines = array_filter(array_map('trim', explode("\n", $c)), fn($line) => strtolower(explode(";", $line)[0]) !== strtolower($u));
                $lines[] = "{$u};{$l}";
                file_put_contents($concurrent_limit_file, implode("\n", $lines) . "\n");
                $message = "Limite ajoutee"; $message_type = "success";
            }
            break;
        case 'edit_user_limit':
            $old = trim($_POST['old_username']); $new = trim($_POST['new_username']); $l = intval($_POST['ip_limit']);
            $c = file_exists($concurrent_limit_file) ? file_get_contents($concurrent_limit_file) : "";
            $lines = array_filter(array_map('trim', explode("\n", $c)), fn($line) => strtolower(explode(";", $line)[0]) !== strtolower($old));
            $lines[] = "{$new};{$l}";
            file_put_contents($concurrent_limit_file, implode("\n", $lines) . "\n");
            $message = "Limite modifiee"; $message_type = "success";
            break;
        case 'delete_user_limit':
            $u = trim($_POST['username']);
            $c = file_exists($concurrent_limit_file) ? file_get_contents($concurrent_limit_file) : "";
            $lines = array_filter(array_map('trim', explode("\n", $c)), fn($line) => strtolower(explode(";", $line)[0]) !== strtolower($u));
            file_put_contents($concurrent_limit_file, implode("\n", $lines) . ($lines ? "\n" : ""));
            $message = "Limite supprimee"; $message_type = "success";
            break;
        // SERVICE
        case 'start_service': exec("systemctl start tautulliipenforcer.service 2>&1", $o, $r); $message = $r === 0 ? "Service demarre" : "Erreur"; $message_type = $r === 0 ? "success" : "error"; break;
        case 'stop_service': exec("systemctl stop tautulliipenforcer.service 2>&1", $o, $r); $message = $r === 0 ? "Service arrete" : "Erreur"; $message_type = $r === 0 ? "success" : "error"; break;
        case 'restart_service': exec("systemctl restart tautulliipenforcer.service 2>&1", $o, $r); $message = $r === 0 ? "Service redemarre" : "Erreur"; $message_type = $r === 0 ? "success" : "error"; break;
        case 'install_service':
            $sc = "[Unit]\nDescription=Tautulli IP Enforcer\nAfter=network.target\n\n[Service]\nType=simple\nRestart=always\nRestartSec=1\nUser=root\nExecStart=/bin/bash {$script_path}tautulliIpEnforcer.sh\n\n[Install]\nWantedBy=multi-user.target";
            file_put_contents("/tmp/tie.service", $sc);
            exec("sudo cp /tmp/tie.service /etc/systemd/system/tautulliipenforcer.service && sudo systemctl daemon-reload 2>&1", $o, $r);
            $message = $r === 0 ? "Service installe" : "Erreur installation"; $message_type = $r === 0 ? "success" : "error";
            break;
    }
}

// HELPER FUNCTIONS
function updatePythonScript($path, $ip, $port, $api, $bm, $cm) {
    $f = $path . "tautulliIpEnforcer.py";
    if (!file_exists($f)) return;
    $c = file_get_contents($f);
    $c = preg_replace('/tautulliIp\s*=\s*"[^"]*"/', "tautulliIp = \"{$ip}\"", $c);
    $c = preg_replace('/tautulliPort\s*=\s*\d+/', "tautulliPort = {$port}", $c);
    $c = preg_replace('/tautulliApi\s*=\s*"[^"]*"/', "tautulliApi = \"{$api}\"", $c);
    $c = preg_replace('/blackListMsg\s*=\s*"[^"]*"/', "blackListMsg = \"{$bm}\"", $c);
    $c = preg_replace('/concurrentMsg\s*=\s*"[^"]*"/', "concurrentMsg = \"{$cm}\"", $c);
    file_put_contents($f, $c);
}

function getServiceStatus() {
    exec("systemctl is-active tautulliipenforcer.service 2>&1", $o, $r); $active = ($r === 0);
    exec("systemctl is-enabled tautulliipenforcer.service 2>&1", $o, $r); $enabled = ($r === 0);
    return ['active' => $active, 'enabled' => $enabled];
}

function getBannedIps() {
    global $banned_ips_file;
    if (!file_exists($banned_ips_file)) return [];
    return array_filter(array_map('trim', file($banned_ips_file)), fn($ip) => !empty($ip));
}

function getUserLimits() {
    global $concurrent_limit_file;
    if (!file_exists($concurrent_limit_file)) return [];
    $limits = [];
    foreach (file($concurrent_limit_file) as $line) {
        $line = trim($line); $parts = explode(";", $line);
        if (count($parts) === 2) $limits[] = ['username' => $parts[0], 'limit' => $parts[1]];
    }
    return $limits;
}

function getLogs($n = 100) {
    global $enforce_log_file;
    if (!file_exists($enforce_log_file)) return [];
    $lines = file($enforce_log_file);
    return array_slice(array_filter(array_map('trim', $lines)), -$n);
}

// Get data
$active_tab = $_GET['tab'] ?? 'banned';
$banned_ips = getBannedIps();
$user_limits = getUserLimits();
$logs = getLogs();
$service_status = getServiceStatus();
